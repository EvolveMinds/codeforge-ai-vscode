{
  "name": "evolve-ai",
  "displayName": "Evolve AI",
  "description": "Free AI coding assistant with auto-detecting stack plugins. Runs locally with Ollama & Gemma 4 (private, offline) or cloud (Claude, OpenAI, HuggingFace). 13 plugins for Databricks, Terraform, Docker, K8s, Django, FastAPI & more. Now with deterministic code cleanup (Biome, Ruff, ESLint, Prettier, gofmt, rustfmt).",
  "version": "1.8.0",
  "publisher": "codeforge-ai",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "MIT",
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Data Science",
    "Testing"
  ],
  "keywords": [
    "ai",
    "copilot alternative",
    "ollama",
    "gemma",
    "code assistant"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/EvolveMinds/codeforge-ai-vscode"
  },
  "homepage": "https://github.com/EvolveMinds/codeforge-ai-vscode#readme",
  "bugs": {
    "url": "https://github.com/EvolveMinds/codeforge-ai-vscode/issues"
  },
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "In untrusted workspaces, Evolve AI ignores workspace-level overrides of provider host URLs (aiForge.ollamaHost, aiForge.openaiBaseUrl, aiForge.huggingfaceBaseUrl). Chat still works using your user-level provider settings. This prevents a malicious workspace from redirecting your code to an attacker-controlled server."
    }
  },
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/codeforge-ai.evolve-ai?label=version&color=blue",
      "href": "https://marketplace.visualstudio.com/items?itemName=codeforge-ai.evolve-ai",
      "description": "Version"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/i/codeforge-ai.evolve-ai?color=green",
      "href": "https://marketplace.visualstudio.com/items?itemName=codeforge-ai.evolve-ai",
      "description": "Installs"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/r/codeforge-ai.evolve-ai?color=yellow",
      "href": "https://marketplace.visualstudio.com/items?itemName=codeforge-ai.evolve-ai",
      "description": "Rating"
    },
    {
      "url": "https://img.shields.io/github/license/EvolveMinds/codeforge-ai-vscode?color=brightgreen",
      "href": "https://github.com/EvolveMinds/codeforge-ai-vscode/blob/main/LICENSE",
      "description": "MIT License"
    }
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-forge",
          "title": "Evolve AI",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "ai-forge": [
        {
          "type": "webview",
          "id": "aiForge.chatPanel",
          "name": "AI Chat"
        }
      ]
    },
