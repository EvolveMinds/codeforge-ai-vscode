    "keybindings": [
      {
        "command": "aiForge.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "aiForge.generateFromDesc",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g"
      },
      {
        "command": "aiForge.fixErrors",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f"
      },
      {
        "command": "aiForge.explainSelection",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorHasSelection"
      },
      {
        "command": "aiForge.gitCommitMessage",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m"
      },
      {
        "command": "aiForge.lineage.showPanel",
        "key": "ctrl+alt+l",
        "mac": "cmd+alt+l"
      },
      {
        "command": "aiForge.queryAnalysis.previewActive",
        "key": "ctrl+alt+q",
        "mac": "cmd+alt+q"
      },
      {
        "command": "aiForge.dbt.impact",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorLangId == sql || editorLangId == jinja-sql"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "aiForge.openChatTab",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "submenu": "aiForge.submenu",
          "group": "aiforge@1",
          "when": "editorTextFocus"
        }
      ],
      "aiForge.submenu": [
        {
          "command": "aiForge.explainSelection",
          "when": "editorHasSelection",
          "group": "1_understand@1"
        },
        {
          "command": "aiForge.refactorSelection",
          "when": "editorHasSelection",
          "group": "1_understand@2"
        },
        {
          "command": "aiForge.fixErrors",
          "group": "2_fix@1"
        },
        {
          "command": "aiForge.analysis.runNow",
          "group": "2_fix@2"
        },
        {
          "command": "aiForge.addDocstrings",
          "group": "2_fix@3"
        },
        {
          "command": "aiForge.addTests",
          "group": "3_generate@1"
        },
        {
          "command": "aiForge.generateFromDesc",
          "group": "3_generate@2"
        },
        {
          "command": "aiForge.gitCommitMessage",
          "group": "4_git@1"
        },
        {
          "command": "aiForge.gitExplainDiff",
          "group": "4_git@2"
        }
      ],
      "scm/title": [
        {
          "command": "aiForge.gitCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "explorer/context": [
        {
          "command": "aiForge.applyToFolder",
          "when": "explorerResourceIsFolder",
          "group": "aiforge"
        }
      ]
    },
    "submenus": [
      {
        "id": "aiForge.submenu",
        "label": "Evolve AI"
      }
    ],
    "configuration": {
      "title": "Evolve AI",
      "properties": {
        "aiForge.provider": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "ollama",
            "gemma4",
            "anthropic",
            "openai",
            "huggingface",
            "offline"
          ],
          "enumDescriptions": [
            "Auto-detect: use Ollama if running, else offline AI",
            "Ollama — local LLM, private, free. Also works with LM Studio, llama.cpp, and Jan via ollamaHost",
            "Gemma 4 — Google's open multimodal model, runs locally via Ollama. Free, private, Apache 2.0. Guided setup included",
            "Anthropic Claude — cloud, requires API key",
            "OpenAI / compatible — works with OpenAI, Groq, Mistral, Together AI, or any OpenAI-compatible endpoint",
            "Hugging Face Inference API — cloud, requires API key. Access thousands of open models",
            "Built-in offline AI — no LLM, pattern-based, instant"
          ],
          "description": "AI provider to use"
        },
        "aiForge.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "pattern": "^https?://",
          "patternErrorMessage": "Must be an http:// or https:// URL.",
          "description": "Ollama server URL. Only http:// and https:// schemes are allowed."
        },
        "aiForge.ollamaModel": {
          "type": "string",
          "default": "qwen2.5-coder:7b",
          "description": "Ollama model to use"
        },
        "aiForge.gemma4Model": {
          "type": "string",
          "default": "gemma4:e4b",
          "enum": [
            "gemma4:e2b",
            "gemma4:e4b",
            "gemma4:26b",
            "gemma4:31b"
          ],
          "enumDescriptions": [
            "E2B — 2.3B active params, ~7.2GB download, fast, good for quick tasks (text+image+audio)",
            "E4B — 4.5B active params, ~9.6GB download, balanced speed and quality (text+image+audio, recommended)",
            "26B MoE — 25.2B total (3.8B active), ~18GB download, high quality reasoning (text+image, needs 32GB+ RAM)",
            "31B Dense — 30.7B params, ~20GB download, highest quality (text+image, needs 32GB+ RAM and GPU)"
          ],
          "description": "Gemma 4 model variant. E4B recommended for most users."
        },
        "aiForge.gemma4ThinkingMode": {
          "type": "boolean",
          "default": false,
          "description": "Enable Gemma 4 thinking/reasoning mode. Shows chain-of-thought reasoning before the answer. Produces better results for complex tasks but uses more tokens and is slower."
        },
        "aiForge.allowHardwareDetection": {
          "type": "boolean",
          "default": true,
          "description": "Allow Evolve AI to check your system (RAM, GPU, disk space, Ollama version) to recommend the best Gemma 4 variant. No data leaves your machine. First use will ask for explicit consent."
        },
        "aiForge.allowAutoInstall": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, the Gemma 4 wizard installs/upgrades Ollama without asking per-step consent (the wizard's main 'Install Everything' button still requires explicit click). When disabled (default), the wizard shows a confirmation dialog before downloading the Ollama installer."
        },
        "aiForge.openaiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI-compatible base URL (Groq, Mistral, LM Studio, etc.)"
        },
        "aiForge.openaiModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "OpenAI model name"
        },
        "aiForge.anthropicModel": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Anthropic model to use (e.g., claude-sonnet-4-6, claude-opus-4-6)"
        },
        "aiForge.huggingfaceModel": {
          "type": "string",
          "default": "Qwen/Qwen2.5-Coder-32B-Instruct",
          "description": "Hugging Face model ID (e.g., Qwen/Qwen2.5-Coder-32B-Instruct, meta-llama/Llama-3.3-70B-Instruct, mistralai/Mistral-Small-24B-Instruct-2501)"
        },
        "aiForge.huggingfaceBaseUrl": {
          "type": "string",
          "default": "https://api-inference.huggingface.co",
          "description": "Hugging Face Inference API base URL (change for dedicated endpoints)"
        },
        "aiForge.codeLensEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Evolve AI hints above functions (Code Lens)"
        },
        "aiForge.includeErrorsInContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically include current diagnostics/errors in AI context"
        },
        "aiForge.includeGitDiffInContext": {
          "type": "boolean",
          "default": false,
          "description": "Automatically include git diff in AI context"
        },
        "aiForge.maxContextFiles": {
          "type": "number",
          "default": 5,
          "description": "Max number of related files to include as context"
        },
        "aiForge.autoRunFix": {
          "type": "boolean",
          "default": false,
          "description": "Automatically attempt to fix errors after running a script"
        },
        "aiForge.contextBudgetChars": {
          "type": "number",
          "default": 24000,
          "description": "Total character budget shared across all context parts (active file, related files, git diff, plugin data). Increase for larger models, decrease for faster/cheaper ones."
        },
        "aiForge.disabledPlugins": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of plugin IDs to disable. E.g. [\"databricks\", \"dbt\"]. Disabled plugins are never activated even when detected."
        },
        "aiForge.lineage.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Resolve upstream table schemas (dbt refs/sources, Spark tables, Unity Catalog) and inject them into AI prompts so suggestions use real column names."
        },
        "aiForge.lineage.includePii": {
          "type": "boolean",
          "default": false,
          "description": "Include columns tagged pii / pci / sensitive when sending prompts to cloud AI providers (Anthropic, OpenAI, Hugging Face). Local providers (Ollama, Gemma 4) always receive full schemas."
        },
        "aiForge.lineage.maxUpstreamTables": {
          "type": "number",
          "default": 8,
          "description": "Maximum number of upstream tables resolved per AI request. Lower values save budget; higher values give the AI more context."
        },
        "aiForge.lineage.providerOrder": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["dbtManifest", "schemaYml", "unityCatalog"],
          "description": "Preferred order for resolving upstream schemas. The first provider to return a match wins."
        },
        "aiForge.queryAnalysis.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens / Hover cost previews for SQL statements when a connected query engine (Databricks, BigQuery) is available."
        },
        "aiForge.queryAnalysis.databricksUsdPerTb": {
          "type": "number",
          "default": 5,
          "description": "Cost-per-TB-scanned used for Databricks USD estimates. Override to match your workspace pricing (Serverless / Pro SQL warehouses vary)."
        },
        "aiForge.queryAnalysis.bigqueryUsdPerTb": {
          "type": "number",
          "default": 5,
          "description": "Cost-per-TB-scanned used for BigQuery USD estimates. BigQuery on-demand pricing is typically $5/TB."
        },
        "aiForge.queryAnalysis.databricksWarehouseId": {
          "type": "string",
          "default": "",
          "description": "SQL warehouse ID used by the cost-preview analyzer. Set automatically the first time you run a cost preview; clear to be re-prompted."
        },
        "aiForge.dbt.impactCodeLensEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a CodeLens at the top of every dbt model with downstream impact (number of dependent models, exposures, tests)."
        },
        "aiForge.dbt.impactDepth": {
          "type": "number",
          "default": 5,
          "description": "Maximum depth (in graph hops) when computing transitive downstream impact. Higher values cover more of the DAG but cost more to compute."
        },
        "aiForge.codeAnalysis.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable deterministic code analysis (ESLint, Prettier, Biome, Ruff, gofmt, rustfmt)."
        },
        "aiForge.codeAnalysis.trigger": {
          "type": "string",
          "enum": ["onOpen", "onSave", "onFocus", "manual"],
          "default": "onSave",
          "description": "When to automatically run code analysis. 'manual' disables automatic runs; use the status bar or the 'Analyze & Clean' command."
        },
        "aiForge.codeAnalysis.debounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce delay before analysis runs after the trigger fires."
        },
        "aiForge.codeAnalysis.scope.maxFileSizeKb": {
          "type": "number",
          "default": 1024,
          "description": "Skip files larger than this size (KB)."
        },
        "aiForge.codeAnalysis.scope.exclude": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/.next/**",
            "**/out/**",
            "**/build/**",
            "**/target/**",
            "**/*.generated.*"
          ],
          "description": "Glob patterns to exclude from analysis."
        },
        "aiForge.codeAnalysis.ui.surface": {
          "type": "string",
          "enum": ["statusBar", "popup", "both"],
          "default": "statusBar",
          "description": "Where to surface analysis results. 'statusBar' is least intrusive; 'popup' prompts above the threshold; 'both' always prompts."
        },
        "aiForge.codeAnalysis.ui.popupThreshold": {
          "type": "number",
          "default": 10,
          "description": "Minimum number of issues before a popup is shown (when surface = 'popup' or 'both')."
        },
        "aiForge.codeAnalysis.consent.autoApply": {
          "type": "object",
          "default": {
            "whitespace": true,
            "quotes": true,
            "semicolons": true,
            "importOrder": true,
            "unusedVars": false,
            "anyTypes": false
          },
          "description": "Which fix categories are considered 'safe' and may be auto-applied (when consent allows)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "postinstall": "node scripts/download-binaries.js",
    "download-bins": "node scripts/download-binaries.js",
    "download-bins:all": "node scripts/download-binaries.js --all",
    "package": "vsce package",
    "package:win-x64":    "node scripts/download-binaries.js --platform=win32-x64    && vsce package --target win32-x64",
    "package:win-arm64":  "node scripts/download-binaries.js --platform=win32-arm64  && vsce package --target win32-arm64",
    "package:mac-x64":    "node scripts/download-binaries.js --platform=darwin-x64  && vsce package --target darwin-x64",
    "package:mac-arm64":  "node scripts/download-binaries.js --platform=darwin-arm64 && vsce package --target darwin-arm64",
    "package:linux-x64":  "node scripts/download-binaries.js --platform=linux-x64   && vsce package --target linux-x64",
    "package:linux-arm64":"node scripts/download-binaries.js --platform=linux-arm64 && vsce package --target linux-arm64",
    "test": "node ./out/test/runTest.js"
  },
